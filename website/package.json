  },
  "resolutions": {
    "qs": "^6.14.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.0",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.14",
    "@types/react-dom": "^18.2.6",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.0",
    "vite-plugin-webfont-dl": "^3.12.0"
  },
  "scripts": {
    "prepare": "yarn build",
    "format": "prettier --write --config .prettierrc src/**/*.{ts,tsx,mjs}",
    "lint": "prettier --check --config .prettierrc src/**/*.{ts,tsx,mjs} && eslint -c eslint.config.mjs src",
    "build": "tsc -p ./configs/app.tsconfig.json && vite build",
    "dev": "vite dev",
    "preview": "vite preview"
  },
  "packageManager": "yarn@4.9.1"
